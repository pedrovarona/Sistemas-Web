# Schema a crear
{
    "$schema": "https://json-schema.org/draft/2020-12/schema#",
    "$id": "http://example.com/schemas/squad.schema.json",
    "type": "object",
    "title": "Squads",
    "description": "Squad Information",
    "required": ["squadName", "homeTown", "formed", "secretBase", "active", "members"],
    "properties": {
        "squadName": {
            "type": "string",
            "description": "Squad Name"
            },
        "homeTown": {
            "type": "string",
            "maxLength": 50,
            "description": "Name of the hometown"
            },
        "formed": {
            "type": "integer",
            "description": "When was the squad formed"
            },
        "secretBase": {
            "type": "string",
            "description": "Secret Base of the squad"
        },
        "active": {
            "type": "boolean",
            "description" : "If the squad is active or not"
        },
        "members" : {
            "type" : "array",
            "items":{
                "type": "object",
                "required": ["name", "age", "secretIdentity", "powers"],
                "properties":{
                    "name":{
                        "type": "string",
                        "description": "Name of the member"
                    },
                    "age":{
                        "type": "integer",
                        "description": "Age of the member"
                    },
                    "secretIdentity":{
                        "type": "string",
                        "description": "Secret identity of the member"
                    },
                    "powers":{
                        "type": "array",
                        "items":{
                            "type": "string"
                        },
                        "description": "Powers of the member"
                    }
                }
            }

        }
    }
}
