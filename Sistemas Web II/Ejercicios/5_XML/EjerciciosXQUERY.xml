# 1A Devuelve los titulos de todos los libros ordenados por precio de mayor a menor
for $book in doc("archivo.xml")//book
order by $book/price descending
return $book/title

# 1B Devuelve los titulos de todos los libros publicados después de 1993, ordenados por año ascendente
for $book in doc("archivo.xml")//book
where $book/@year > 1993
order by $book/@year ascending
return $book/title

# 1C Devuelve título y precio de los libros con un precio mayor que 60 en el siguiente formato:
# <expensiveBook>
#   <title>...</title>
#   <price>...</price>
#  </expensiveBook>

for $book in doc("archivo.xml")//book
where $book/price > 60
return
    <expensiveBook>
        <title>{data($book/title)}</title>
        <price>{data($book/price)}</price>
    </expensiveBook>

# 2A Cuantos libros ha escrito Abiteboul
count(doc("archivo.xml")//book[author = "Abiteboul"])

# 2B Devuelve los titulos de los libros que tengan como autor a Stevens
for $book in doc("archivo.xml")//book
where $book/author = "Stevens"
return $book/title

# 2C Devuelve los autores distintos, sin repetir
distinct-values(doc("archivo.xml")//book/author)


# Crear XML resumen por autores con la estructura:
# <authors>
#   <author>
#     <name>Stevens</name>
#     <count>2</count>
#   </author>
#   <author>
# etc

<authors>
{
    for $author in distinct-values(doc("archivo.xml")//book/author)
    return
        <author>
            <name>{$author}</name>
            <count>{ count(doc("archivo.xml")//book[author = $author])}</count>
        </author>
}
</authors>


# 4A Clasificar libros por precio. Si el precio es mayor que 60 devolvemos:
# <expensive>titulo</expensive>
# si es menor que 60 devolvemos:
# <normal>titulo</normal>

for $book in doc("archivo.xml")//book
return
    if ($book/price > 60)
    then <expensive>{data($book/title)}</expensive>
    else <normal>{data($book/title)}</normal>


# 4B Numerar los titulos de la forma:
# <book>1. TCP/IP Illustrated</book>
# <book>2. Principles of Databases</book>

for $book at $i in doc("archivo.xml")//book
return <book>{$i}. {data($book/title)}</book>


# 4C Crear resumen de libros caros (precio > 60)
<summary>
    <totalExpensive>{count(doc("archivo.xml")//book[price > 60])}</totalExpensive>
    <books>
        {
            for $book in doc("archivo.xml")//book
            where $book/price > 60
            return
                <book>
                    <title>{data($book/title)}</title>
                    <price>{data($book/price)}</price>
                </book>
        }
    </books>
</summary>

# 4D Mostrar libros con número de orden por precio de mayor a menor

for $book at $i in doc("archivo.xml")//book
order by $book/price descending
return <book>{$i}. {data($book/title)}</book>

# otra forma seria
let $orderedBooks :=
  for $book in doc("archivo.xml")//book
  order by $book/price descending
  return $book

for $book at $i in $orderedBooks
return <book>{$i}. {data($book/title)}</book>


# 4E Crear un XML clasificando libros por autor con la forma (single author solo un autor y milti author varios)
# <books>
#   <book>
#     <title>TCP/IP Illustrated</title>
#     <type>single-author</type>
#   </book>
#   <book>

<books>
{
    for $book in doc("archivo.xml")//book
    return
        <book>
            <title>{data($book/title)}</title>
            {
                if (count($book/author) = 1)
                then <type>single-author</type>
                else <type>multi-author</type>
            }
        </book>
}
</books>